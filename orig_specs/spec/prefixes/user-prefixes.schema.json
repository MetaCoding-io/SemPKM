{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sempkm.org/schemas/prefixes/user-prefixes.schema.json",
  "title": "SemPKM User Prefix Overrides (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "prefixes"],
  "properties": {
    "schema": { "type": "string", "const": "sempkm.user-prefixes.v1" },
    "prefixes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["prefix", "namespace"],
        "properties": {
          "prefix": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z_][A-Za-z0-9_\\-\\.]*$"
          },
          "namespace": { "type": "string", "format": "uri" }
        }
      }
    }
  }
}