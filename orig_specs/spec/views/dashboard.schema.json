{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sempkm.org/schemas/views/dashboard.schema.json",
  "title": "SemPKM Dashboard View Spec (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "renderer", "params", "layout"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "renderer": { "type": "string", "const": "dashboard" },

    "params": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/param" }
    },

    "layout": { "$ref": "#/$defs/layout" }
  },

  "allOf": [
    {
      "description": "Require a contextIri param.",
      "contains": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "const": "contextIri" },
          "type": { "const": "iri" }
        }
      }
    }
  ],

  "$defs": {
    "param": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "enum": ["iri", "string", "number", "boolean"] },
        "required": { "type": "boolean", "default": true },
        "description": { "type": "string" }
      }
    },

    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["grid", "panels"],
      "properties": {
        "grid": {
          "type": "object",
          "additionalProperties": false,
          "required": ["columns"],
          "properties": {
            "columns": { "type": "integer", "minimum": 1, "maximum": 48 }
          }
        },
        "panels": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/panel" }
        }
      }
    },

    "panel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "title", "position"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "enum": ["objectSelf", "view", "lintSummary", "markdown"] },
        "title": { "type": "string", "minLength": 1 },

        "position": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y", "w", "h"],
          "properties": {
            "x": { "type": "integer", "minimum": 0 },
            "y": { "type": "integer", "minimum": 0 },
            "w": { "type": "integer", "minimum": 1 },
            "h": { "type": "integer", "minimum": 1 }
          }
        },

        "viewId": { "type": "string", "minLength": 1 },
        "params": {
          "type": "object",
          "description": "Panel parameter bindings (string templating allowed, e.g., {{contextIri}}).",
          "additionalProperties": { "type": ["string", "number", "boolean"] },
          "default": {}
        },

        "markdown": { "type": "string" }
      },

      "allOf": [
        {
          "if": { "properties": { "type": { "const": "view" } } },
          "then": { "required": ["viewId"] }
        },
        {
          "if": { "properties": { "type": { "const": "markdown" } } },
          "then": { "required": ["markdown"] }
        },
        {
          "if": { "properties": { "type": { "const": "objectSelf" } } },
          "then": {
            "not": {
              "anyOf": [
                { "required": ["viewId"] },
                { "required": ["markdown"] }
              ]
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "lintSummary" } } },
          "then": {
            "not": {
              "anyOf": [
                { "required": ["viewId"] },
                { "required": ["markdown"] }
              ]
            }
          }
        }
      ]
    }
  }
}