    {
      "@id": "bpkm:seed-note-architecture",
      "@type": "bpkm:Note",
      "dcterms:title": "Architecture Decision: Event Sourcing",
      "bpkm:body": "After evaluating several persistence strategies, we decided to use event sourcing with RDF triplestores. Each mutation is stored as an immutable event, and the current state is materialized by replaying events. This gives us full audit history and enables temporal queries.\n\n## Key Points\n- Events stored as named graphs with timestamps\n- Materialized view updated via SPARQL INSERT/DELETE\n- Sentinel triples prevent empty graph deletion in RDF4J",
      "bpkm:noteType": "reference",
      "bpkm:tags": ["architecture", "event-sourcing", "decision"],
      "dcterms:created": { "@value": "2026-01-18T14:30:00Z", "@type": "xsd:dateTime" },
      "bpkm:isAbout": [
        { "@id": "bpkm:seed-concept-event-sourcing" }
      ],
      "bpkm:relatedProject": { "@id": "bpkm:seed-project-sempkm" }
    },
    {
      "@id": "bpkm:seed-note-kickoff",
      "@type": "bpkm:Note",
      "dcterms:title": "Meeting: Project Kickoff",
      "bpkm:body": "Kickoff meeting for the SemPKM project. Discussed goals, timeline, and initial architecture.\n\n## Attendees\n- Alice Chen (Lead Developer)\n- Bob Martinez (Product Designer)\n\n## Decisions\n- Use RDF4J as the triplestore\n- Start with Basic PKM mental model\n- Target 5-phase implementation plan",
      "bpkm:noteType": "meeting-note",
      "bpkm:tags": ["meeting", "kickoff", "planning"],
      "dcterms:created": { "@value": "2026-01-15T10:00:00Z", "@type": "xsd:dateTime" },
      "bpkm:relatedProject": { "@id": "bpkm:seed-project-sempkm" }
    },
    {
      "@id": "bpkm:seed-note-graph-viz",
      "@type": "bpkm:Note",
      "dcterms:title": "Idea: Graph Visualization",
      "bpkm:body": "Explore using Cytoscape.js for interactive graph visualization of knowledge connections. The graph view should show nodes for each entity and edges for relationships, with different colors per type.\n\n## Considerations\n- Performance with large graphs (1000+ nodes)\n- Layout algorithms (force-directed vs hierarchical)\n- Integration with SPARQL CONSTRUCT queries",
      "bpkm:noteType": "idea",
      "bpkm:tags": ["visualization", "graph", "cytoscape"],
      "dcterms:created": { "@value": "2026-02-05T16:00:00Z", "@type": "xsd:dateTime" },
      "bpkm:isAbout": [
        { "@id": "bpkm:seed-concept-semantic-web" }
      ]
    },

