      "skos:prefLabel": "Semantic Web",
      "skos:altLabel": "Web of Data",
      "skos:definition": "An extension of the World Wide Web that enables data to be shared and reused across applications using standards like RDF, OWL, and SPARQL.",
      "skos:related": [
